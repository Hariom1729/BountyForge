generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  githubId      String?   @unique
  githubUsername String?
  googleId      String?   @unique
  githubConnected Boolean @default(false)
  guestMode     Boolean   @default(false)
  role          Role      @default(CONTRIBUTOR)
  authProvider  AuthProvider @default(GITHUB)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  organizations Organization[] @relation("OrganizationOwner")
  teamMemberships TeamMember[]
  repositories  Repository[]   @relation("RepositoryOwner")
  bounties      Bounty[]       @relation("BountyCreator")
  claims        Claim[]
  paymentsMade  Payment[]      @relation("Payer")
  paymentsRcvd  Payment[]      @relation("Receiver")
  notifications Notification[]
  reputation    Reputation?
  leaderboard   Leaderboard?
  auditLogs     AuditLog[]
  userSkills    UserSkill[]
  jobApplications JobApplication[]
  fraudScore    FraudScore?
}

enum Role {
  MAINTAINER
  CONTRIBUTOR
  ADMIN
  ENTERPRISE
  GUEST
}

enum AuthProvider {
  GITHUB
  GOOGLE
  GUEST_SESSION
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  owner        User         @relation("OrganizationOwner", fields: [ownerId], references: [id])
  teams        Team[]
  repositories Repository[]
  jobPosts     JobPost[]
}

model Team {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
  members        TeamMember[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model Repository {
  id             String   @id @default(cuid())
  githubRepoId   String   @unique
  name           String
  ownerId        String
  organizationId String?
  healthScore    Float?   @default(100.0)
  createdAt      DateTime @default(now())

  owner        User          @relation("RepositoryOwner", fields: [ownerId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  issues       Issue[]
}

model Issue {
  id            String     @id @default(cuid())
  githubIssueId String     @unique
  title         String
  body          String?    @db.Text
  status        String
  difficulty    Difficulty @default(MEDIUM)
  repositoryId  String
  
  // AI Analyzed Metadata
  estimatedHours Float?
  suggestedReward Float?
  complexityScore Int?
  aiImplementationPlan String? @db.Text
  aiAnalyzedAt   DateTime?

  repository Repository @relation(fields: [repositoryId], references: [id])
  bounty     Bounty?
  issueSkills IssueSkill[]
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?
  
  userSkills  UserSkill[]
  issueSkills IssueSkill[]
  jobSkills   JobSkill[]
}

model UserSkill {
  id        String @id @default(cuid())
  userId    String
  skillId   String
  proficiency Int  @default(1) // 1-10

  user      User  @relation(fields: [userId], references: [id])
  skill     Skill @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
}

model IssueSkill {
  id        String @id @default(cuid())
  issueId   String
  skillId   String

  issue     Issue @relation(fields: [issueId], references: [id])
  skill     Skill @relation(fields: [skillId], references: [id])

  @@unique([issueId, skillId])
}

model Bounty {
  id        String       @id @default(cuid())
  amount    Float
  status    BountyStatus @default(OPEN)
  issueId   String       @unique
  creatorId String
  createdAt DateTime     @default(now())

  issue   Issue   @relation(fields: [issueId], references: [id])
  creator User    @relation("BountyCreator", fields: [creatorId], references: [id])
  claims  Claim[]
}

enum BountyStatus {
  OPEN
  CLAIMED
  COMPLETED
  CANCELLED
}

model Claim {
  id        String      @id @default(cuid())
  bountyId  String
  userId    String
  status    ClaimStatus @default(PENDING)
  matchScore Float?     // AI Match Score
  claimedAt DateTime    @default(now())

  bounty      Bounty        @relation(fields: [bountyId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  pullRequest PullRequest?

  @@unique([bountyId, userId])
}

enum ClaimStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model PullRequest {
  id         String   @id @default(cuid())
  githubPrId String   @unique
  claimId    String   @unique
  status     String
  mergedAt   DateTime?
  
  // AI Code Review
  aiReviewSummary String? @db.Text
  securityScore   Float?
  qualityScore    Float?
  aiReviewedAt    DateTime?

  claim Claim @relation(fields: [claimId], references: [id])
}

model Payment {
  id         String        @id @default(cuid())
  amount     Float
  status     PaymentStatus @default(PENDING)
  payerId    String
  receiverId String
  createdAt  DateTime      @default(now())

  payer             User               @relation("Payer", fields: [payerId], references: [id])
  receiver          User               @relation("Receiver", fields: [receiverId], references: [id])
  escrowTransaction EscrowTransaction?
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model EscrowTransaction {
  id        String       @id @default(cuid())
  amount    Float
  status    EscrowStatus @default(HELD)
  paymentId String       @unique

  payment Payment @relation(fields: [paymentId], references: [id])
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Reputation {
  id        String   @id @default(cuid())
  userId    String   @unique
  score     Int      @default(0)
  rank      String   @default("Bronze Developer")
  badges    String[] // e.g. ["Bug Hunter", "AI Engineer"]
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Leaderboard {
  id       String @id @default(cuid())
  userId   String @unique
  position Int
  score    Int

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model FraudScore {
  id        String   @id @default(cuid())
  userId    String   @unique
  score     Float    @default(0.0) // 0-100, >80 blocks user
  reasons   String[]
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model JobPost {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  description    String   @db.Text
  type           JobType
  location       String?
  salaryMin      Float?
  salaryMax      Float?
  status         String   @default("OPEN")
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
  jobSkills      JobSkill[]
  applications   JobApplication[]
}

enum JobType {
  FULL_TIME
  FREELANCE
  INTERNSHIP
}

model JobSkill {
  id        String @id @default(cuid())
  jobPostId String
  skillId   String

  jobPost   JobPost @relation(fields: [jobPostId], references: [id])
  skill     Skill   @relation(fields: [skillId], references: [id])

  @@unique([jobPostId, skillId])
}

model JobApplication {
  id        String   @id @default(cuid())
  jobPostId String
  userId    String
  status    String   @default("APPLIED")
  aiMatchScore Float?
  createdAt DateTime @default(now())

  jobPost   JobPost @relation(fields: [jobPostId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([jobPostId, userId])
}
